SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key...
# Token used to authenticate against the iMissive SMS API when a job's profile/template
# uses credential_mode = "manual_token". For backend_secret jobs this env var is also
# read using the secret name stored on the profile/template.
IMISSIVE_API_TOKEN=

RUNNER_ID=runner-1
MAX_CONCURRENCY=20
DEFAULT_RPS=10
POLL_INTERVAL_MS=3000
HEARTBEAT_INTERVAL_MS=3000
